{
  "name": "@zagvar/relay-core",
  "version": "0.2.0",
  "description": "Provider-neutral market data contracts and utilities for Zagvar Relay.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src test",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "author": "zayau",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zagvar/relay.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/zagvar/relay/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/zagvar/relay/issues"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@zagvar/decimal": "^0.1.2",
    "zod": "^4.4.3"
  }
}
