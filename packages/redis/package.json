{
  "name": "@zagvar/relay-redis",
  "version": "0.1.0",
  "description": "Redis-backed cache and pub/sub implementations for Zagvar Relay.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src test",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "author": "zayau",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zagvar/relay.git",
    "directory": "packages/redis"
  },
  "homepage": "https://github.com/zagvar/relay/tree/main/packages/redis#readme",
  "bugs": {
    "url": "https://github.com/zagvar/relay/issues"
  },
  "dependencies": {
    "@zagvar/relay-core": "workspace:*",
    "redis": "^6.1.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
