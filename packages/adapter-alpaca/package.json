{
  "name": "@zagvar/relay-adapter-alpaca",
  "version": "0.0.0",
  "description": "Alpaca market data adapter for Zagvar Relay.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src test",
    "test": "vitest",
    "test:run": "vitest run",
    "smoke:stocks": "pnpm build && node scripts/smoke_stock_stream.mjs"
  },
  "dependencies": {
    "@zagvar/relay-core": "workspace:*",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.4.2",
    "typescript": "^6.0.3"
  }
}
